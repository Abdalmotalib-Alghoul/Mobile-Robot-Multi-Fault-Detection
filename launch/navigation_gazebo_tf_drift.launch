<?xml version="1.0"?>
<launch>
  <!-- Navigation Gazebo Drift Launch File - TF IMU Drift Injection - ENHANCED -->
  <!-- Enhanced with shutdown coordination and robust process management -->
  
  <arg name="navigation_goals" default="true" doc="whether to run automatic navigation goals" />
  
  <!-- Arguments -->
  <arg name="map_yaml" default="/home/talib/catkin_ws/src/stretch_ros/stretch_navigation/maps/map.yaml" />
  <arg name="rviz" default="false" />
  <arg name="gazebo_world" default="/home/talib/catkin_ws/src/stretch_ros/stretch_navigation/worlds/willowgarage.world" />
  <arg name="gazebo_gpu_lidar" default="false" />
  <arg name="gazebo_visualize_lidar" default="false" />

  
  <!-- TF IMU Drift Parameters -->
  <arg name="pose_x_offset" default="0.0" doc="pose_x_offset" />
  <arg name="pose_ang_z_offset" default="0.0" doc="pose_ang_z_offset" />
  <arg name="acceleration_x_rate" default="0.0 " doc="Acceleration bias in m/s² (IMU drift)" />
  <arg name="angular_velocity_z_rate" default="0.0" doc="Angular velocity bias in rad/s (IMU drift)" />
  <arg name="experiment_duration" default="300.0" doc="Experiment duration in seconds" />
  <arg name="scenario_name" default="normal_operation" doc="Name of the current scenario" />
  <arg name="run_id" default="1" doc="ID of the current run" />
  <arg name="injector_save_dir" default="/home/talib/catkin_ws/Plot/tf_analysis" doc="Directory for dataset_collector to save CSVs" />
  <arg name="warmup_duration" default="0.2" doc="Warmup duration in seconds before drift starts" />
  <arg name="logging_frequency" default="10.0" doc="Data collection frequency in Hz" />

  <!-- GAZEBO SIMULATION -->
  <include file="$(find stretch_gazebo)/launch/gazebo.launch">
    <arg name="world" value="$(arg gazebo_world)" />
    <arg name="visualize_lidar" value="$(arg gazebo_visualize_lidar)" />
    <arg name="gpu_lidar" value="$(arg gazebo_gpu_lidar)" />
    <arg name="gui" value="false" />
   
  </include>

  <!-- MAP SERVER -->
  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_yaml)" />

  <!-- LOCALIZATION - Uses anomalous TF data -->
  <include file="$(find amcl)/examples/amcl_diff.launch">
    <remap from="/tf" to="/tf_anomalous" />
    <remap from="/tf_static" to="/tf_static_anomalous" />

  </include>
  
  <!-- TF IMU DRIFT INJECTION - ENHANCED -->
  <node pkg="stretch_navigation" type="tf_drift_injector.py" name="tf_drift_injector" output="screen" respawn="false">
    <param name="pose_x_offset" value="$(arg pose_x_offset)" />
    <param name="pose_ang_z_offset" value="$(arg pose_ang_z_offset)" />
    <param name="acceleration_x_rate" value="$(arg acceleration_x_rate)" />
    <param name="angular_velocity_z_rate" value="$(arg angular_velocity_z_rate)" />
    <param name="experiment_duration" value="$(arg experiment_duration)" />
    <param name="warmup_duration" value="$(arg warmup_duration)" />
    <param name="scenario_name" value="$(arg scenario_name)" />
    <param name="run_id" value="$(arg run_id)" />
  </node>

  <!-- DATASET COLLECTOR - SIMPLIFIED ROBUST VERSION -->
  <node pkg="stretch_navigation" type="dataset_collector.py" name="dataset_collector" output="screen" respawn="false">
  
    <remap from="/tf"           to="/tf_anomalous_diagnose" />
    <remap from="/tf_static"    to="/tf_static_anomalous" />
  
  
    <param name="pose_x_offset" value="$(arg pose_x_offset)" />
    <param name="pose_ang_z_offset" value="$(arg pose_ang_z_offset)" />
    <param name="acceleration_x_rate" value="$(arg acceleration_x_rate)" />
    <param name="angular_velocity_z_rate" value="$(arg angular_velocity_z_rate)" />
    <param name="experiment_duration" value="$(arg experiment_duration)" />
    <param name="warmup_duration" value="$(arg warmup_duration)" />
    <param name="logging_frequency" value="$(arg logging_frequency)" />
    <param name="scenario_name" value="$(arg scenario_name)" />
    <param name="run_id" value="$(arg run_id)" />
    <param name="injector_save_dir" value="$(arg injector_save_dir)" />
    <remap from="/fault_labels" to="/fault_labels"/>
  </node>

  <!-- NAVIGATION - Uses anomalous TF data -->
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <rosparam file="$(find stretch_navigation)/config/common_costmap_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find stretch_navigation)/config/common_costmap_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find stretch_navigation)/config/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find stretch_navigation)/config/global_costmap_params_withmap.yaml" command="load" />
    <rosparam file="$(find stretch_navigation)/config/base_local_planner_params.yaml" command="load" />
    <rosparam file="$(find stretch_navigation)/config/recovery_behaviors.yaml" command="load" />
    
    <!-- Use anomalous TF data for navigation -->
    <remap from="/tf" to="/tf_anomalous" />
    <remap from="/tf_static" to="/tf_static_anomalous" />
    <remap from="/cmd_vel" to="/stretch_diff_drive_controller/cmd_vel" />
    <remap from="scan_filtered" to="/scan" />

  </node>
  
    <!-- NAVIGATION FAILURE MONITOR - COORDINATED SHUTDOWN ON FAIL -->
  <node pkg="stretch_navigation" type="failure_monitor.py" name="failure_monitor" output="screen" respawn="false">
    <param name="timeout_sec" value="30.0" />  <!-- Tune per scenario -->
    <param name="max_drift_m" value="1.5" />
    <param name="max_covariance" value="1.0" />
  </node>
  
  <!-- AUTOMATIC NAVIGATION GOALS - WITH SHUTDOWN SUPPORT -->
  <node name="robust_nav_goal" pkg="stretch_navigation" type="nav.py" output="screen" if="$(arg navigation_goals)" respawn="false">
    <param name="map_yaml" value="$(arg map_yaml)" />
  </node>

  <!-- VISUALIZE - Uses anomalous TF data -->
  <node name="rviz" pkg="rviz" type="rviz" output="log" args="-d $(find stretch_navigation)/rviz/navigation.rviz" if="$(arg rviz)" respawn="false">
    <remap from="/tf" to="/tf_anomalous" /> 
    <remap from="/tf_static" to="/tf_static_anomalous" /> 

  </node>
  
  <!-- LAUNCH TERMINATOR - WITH SHUTDOWN SIGNAL SUPPORT -->
  <node name="launch_terminator" pkg="stretch_navigation" type="launch_terminator.py" output="screen" respawn="false">
    <param name="duration" value="$(arg experiment_duration)" />
  </node>

  <!-- SHUTDOWN COORDINATION -->
  <!-- All nodes now subscribe to /shutdown_signal for coordinated shutdown -->
</launch>
